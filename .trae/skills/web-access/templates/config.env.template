# web-access skill 用户偏好配置
# 此文件是模板。首次运行 check-deps.mjs 时会自动复制为 config.env（git ignored）。
#
# 用户长期偏好的默认 Agent 浏览器
# - 留空：每次启动都问用户偏好哪个
# - 设值：固定使用该浏览器；若未检测到对应 toggle 则硬错（不擅自降级）
#
# 合法值：chrome / edge
WEB_ACCESS_BROWSER=

# --- human-pace 发布模式（反风控，spec §3.6 F6）---
# 写操作端点（/navigate /click /clickAt /eval /scroll /setFiles）支持 ?pace=human。
# 命中时操作成功后随机睡 [MIN, MAX] ms 再返回，模拟"操作一个停顿一个"。
# 这两个 env 仅对当前 proxy 进程生效（cdp-proxy.mjs 启动时读 process.env）；
# 要生效需重启 proxy（pkill -f cdp-proxy.mjs 后重新跑 check-deps.mjs）。
CDP_HUMAN_PACE_MIN=3000
CDP_HUMAN_PACE_MAX=8000
